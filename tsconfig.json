{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2021"],

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,

    "declaration": true,
    "sourceMap": true,

    "types": ["node"]
  },
  "include": ["src"]
}